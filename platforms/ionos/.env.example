# IONOS Custom Metering Configuration
# Copy this file to .env and update with your actual values

# ========== meshStack Configuration (Required) ==========
# meshStack meshfed API endpoint
MESHSTACK_MESHFED_URL=https://meshfed.example.com

# meshStack Kraken API endpoint
MESHSTACK_KRAKEN_URL=https://kraken.example.com

# meshStack API credentials
MESHSTACK_API_USER=mesh-custom-metering
MESHSTACK_API_SECRET=your-meshstack-api-secret-here

# meshStack platform identifier
PLATFORM_ID=ionos

# ========== IONOS Authentication (Required) ==========
# Username or email associated with your IONOS account
# Note: Only the main contract user can access billing data
IONOS_USERNAME=your-ionos-username-or-email@example.com

# Password for your IONOS account
# Important: Keep this secure! Use secrets management in production.
IONOS_PASSWORD=your-ionos-account-password

# Your IONOS Contract/Account ID
# Find this in your IONOS console: Settings → Contracts → Contract ID
IONOS_CONTRACT=your-contract-id

# IONOS API endpoint (use real API for production)
IONOS_API_URL=https://api.ionos.com
# For testing with mock: http://ionos-mock:5002

# ========== Optional Configuration ==========
# Usage period to collect (defaults to current month)
# Format: YYYY-MM (e.g., 2024-01 for January 2024)
# USAGE_PERIOD=2024-01

# Logging level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional: Loki endpoint for centralized log aggregation
# LOKI_URL=http://loki:3100

# Include deleted tenants in metering (default: true)
# INCLUDE_DELETED_TENANTS=true

# ========== IONOS API Performance (Optional) ==========
# API request timeout in seconds (default: 30)
# Increase this if you have slow network or large datasets
# IONOS_API_TIMEOUT=30

# Maximum number of retry attempts for failed API requests (default: 3)
# Implements exponential backoff: 1s, 2s, 4s between retries
# IONOS_API_RETRIES=3

# ========== Custom Metering Features ==========
# Enable product group information in line items
# When enabled, each line item will include the 'productGroup' field from the IONOS product
# This allows you to categorize services by their product group (e.g., "Compute", "Storage", "Network")
# Default: false
IONOS_INCLUDE_PRODUCT_GROUP=false

# Enable price group information in usageType
# When enabled, price groups are prepended to the usageType field from IONOS invoices API
# This allows you to identify pricing tiers (e.g., "PG 1", "PG A", "PG C1")
# Format: "{PriceGroup} - IONOS Service {meterId}"
# Example: "PG 1 - IONOS Service C01000"
# Default: true
IONOS_INCLUDE_PRICE_GROUP=true

# ========== Seller Configuration ==========
# Seller ID for line items submitted to meshStack
# This value will be used in the 'sellerId' field of each line item
# Default: IONOS
IONOS_SELLER_ID=IONOS

# Seller product group for line items submitted to meshStack
# This value will be used in the 'sellerProductGroup' field of each line item
# Default: IONOS
IONOS_SELLER_PRODUCT_GROUP=IONOS

# ========== SECURITY CONSIDERATIONS ==========
# These credentials grant access to billing data - handle with care!
#
# Option 1: Environment File (.env) - Local Development Only
#   - Copy .env.example to .env
#   - Add your credentials
#   - Ensure file permissions: chmod 600 .env
#   - NEVER commit to version control (add to .gitignore)
#
# Option 2: Kubernetes Secrets - Recommended for Production
#   Create secret:
#     kubectl create secret generic ionos-credentials \
#       --from-literal=IONOS_USERNAME=your-username \
#       --from-literal=IONOS_PASSWORD=your-password \
#       --from-literal=IONOS_CONTRACT=your-contract-id \
#       -n metering
#
#   Then reference in deployment:
#     envFrom:
#     - secretRef:
#         name: ionos-credentials
#
# Option 3: Cloud Secrets Manager
#   - AWS Secrets Manager: aws secretsmanager create-secret ...
#   - Azure Key Vault: az keyvault secret set ...
#   - Google Cloud Secret Manager: gcloud secrets create ...
#
# Option 4: HashiCorp Vault
#   - Store credentials in Vault
#   - Use agent to inject into environment
#   - Automatic rotation support
#
# Best Practices:
#   1. Never hardcode credentials in deployment files
#   2. Rotate credentials regularly
#   3. Use least privilege accounts when possible
#   4. Enable audit logging for credential access
#   5. Monitor for unauthorized API calls
