# ============================================================================
# meshStack Configuration (REQUIRED)
# ============================================================================

# MeshFed API endpoint URL (without trailing slash)
# Example: https://meshfed.example.com
MESHSTACK_MESHFED_URL=https://meshfed.example.com

# Kraken (internal) API endpoint URL (used for tenant resolution if needed)
# Example: https://kraken.example.com
MESHSTACK_KRAKEN_URL=https://kraken.example.com

# API credentials for meshStack authentication
MESHSTACK_API_USER=mesh-custom-metering
MESHSTACK_API_SECRET=your-secret-here

# Platform identifier as configured in meshStack
# This should match the platform ID for AWS in your meshStack setup
PLATFORM_ID=aws


# ============================================================================
# AWS Configuration (REQUIRED)
# ============================================================================

# AWS Region for API calls
# The AWS Cost Explorer and Organizations APIs are available globally,
# but you can specify your preferred region
# Examples: us-east-1, eu-central-1, eu-west-1
AWS_REGION=eu-central-1

# Cost metric to use for metering
# - UnblendedCost: Actual itemized costs per service/usage type
#   Good for detailed cost analysis, reflects real charges
# - AmortizedCost: Spreads upfront commitments and discounts over time
#   Better for smooth cost trends, reflects economical costs
#
# Default: UnblendedCost
AWS_COST_TYPE=UnblendedCost

# Optional: Limit metering to specific AWS accounts (comma-separated)
# If not set, ALL active/suspended accounts in the organization will be processed
# Example: AWS_LINKED_ACCOUNTS=123456789012,210987654321
# AWS_LINKED_ACCOUNTS=

# Optional: Include deleted tenants/accounts in metering
# Default: true
INCLUDE_DELETED_TENANTS=true


# ============================================================================
# Metering Configuration (OPTIONAL)
# ============================================================================

# Period to process in YYYY-MM format
# If not set, defaults to current month
# Example: USAGE_PERIOD=2024-01
# USAGE_PERIOD=

# Whether to include last month in the metering process
# - If not set, defaults to AUTO (process last month if today is in first 5 days)
# - Set to 'true' to always process last month
# - Set to 'false' to never process last month
#
# Useful for backfilling: on the 1st-5th of the month, both current and last
# month are processed to catch any delayed billing data
#
# Examples: INCLUDE_LAST_MONTH=true, INCLUDE_LAST_MONTH=false
# INCLUDE_LAST_MONTH=


# ============================================================================
# Logging Configuration (OPTIONAL)
# ============================================================================

# Logging level for console output
# Values: DEBUG, INFO, WARN, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Optional: Loki URL for centralized log aggregation
# If set, structured logs will also be sent to Loki
# Example: LOKI_URL=http://loki:3100
# LOKI_URL=


# ============================================================================
# AWS Authentication
# ============================================================================
#
# The AWS SDK uses standard authentication chain:
# 1. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# 2. AWS credentials file (~/.aws/credentials)
# 3. IAM role (if running on EC2, ECS, Lambda, etc.)
# 4. Temporary security credentials via STS
#
# For container deployments, it's recommended to use:
# - Option A: Mount AWS credentials file as volume
# - Option B: Use IAM role (recommended for cloud deployments)
# - Option C: Pass credentials via environment variables
#
# Required AWS IAM permissions:
# - ce:GetCostAndUsage (Cost Explorer)
# - organizations:ListAccounts (Organizations)
#
# Minimal IAM policy example:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "ce:GetCostAndUsage"
#       ],
#       "Resource": "*"
#     },
#     {
#       "Effect": "Allow",
#       "Action": [
#         "organizations:ListAccounts"
#       ],
#       "Resource": "*"
#     }
#   ]
# }
