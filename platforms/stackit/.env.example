# meshStack Configuration (required)
MESHSTACK_MESHFED_URL=https://meshfed.example.com
MESHSTACK_KRAKEN_URL=https://kraken.example.com
MESHSTACK_API_USER=mesh-custom-metering
MESHSTACK_API_SECRET=your-secret-here
PLATFORM_ID=stackit

# STACKIT Specific Configuration (required)
# Parent container IDs to process (comma-separated)
CONTAINER_PARENT_IDS=container-parent-id-1,container-parent-id-2

# Seller Configuration
# Seller ID for line items submitted to meshStack
# Default: STACKIT
STACKIT_SELLER_ID=STACKIT

# Seller product group for line items submitted to meshStack
# Default: STACKIT
STACKIT_SELLER_PRODUCT_GROUP=STACKIT

# Metering Configuration (optional)
# Period to process in YYYY-MM format
# If not set, defaults to current month
# USAGE_PERIOD=2024-01

# Whether to include last month in the metering process
# Defaults to AUTO (process last month if today is in first 5 days)
# INCLUDE_LAST_MONTH=false

# Logging Configuration
LOG_LEVEL=INFO
# Optional: Loki URL for centralized log aggregation
# LOKI_URL=http://loki:3100
