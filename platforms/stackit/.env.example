# meshStack Configuration
MESHSTACK_MESHFED_URL=https://meshfed.example.com
MESHSTACK_KRAKEN_URL=https://kraken.example.com
MESHSTACK_API_USER=mesh-custom-metering
MESHSTACK_API_SECRET=your-secret-here
PLATFORM_ID=stackit.production

# STACKIT Authentication (full JSON service account from the STACKIT portal)
STACKIT_SERVICE_ACCOUNT_TOKEN='{"credentials":{...}}' # single-line JSON

# STACKIT Container Parent IDs (comma-separated)
CONTAINER_PARENT_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional Configuration
USAGE_PERIOD=2024-01
LOG_LEVEL=INFO
LOKI_URL=http://loki:3100
