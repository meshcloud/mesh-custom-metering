# meshStack Configuration
MESHSTACK_MESHFED_URL=https://meshfed.example.com
MESHSTACK_KRAKEN_URL=https://kraken.example.com
MESHSTACK_API_USER=mesh-custom-metering
MESHSTACK_API_SECRET=your-secret-here
PLATFORM_ID=oci.production

# OCI Authentication
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaaaaaxxxxx
OCI_USER_OCID=ocid1.user.oc1..aaaaaaaxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=/path/to/oci_api_key.pem
OCI_REGION=us-ashburn-1
OCI_ROOT_COMPARTMENT_ID=ocid1.compartment.oc1..aaaaaaaxxxxx

# Optional Configuration
USAGE_PERIOD=2024-01
LOG_LEVEL=INFO
LOKI_URL=http://loki:3100
